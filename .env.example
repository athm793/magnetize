# Database (Neon PostgreSQL recommended — free tier at neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — create at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI generation via OpenRouter — optional, feature hidden if not set
# Free models available at openrouter.ai (Llama 3, Mistral, etc.)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mistral-7b-instruct

# File uploads via Vercel Blob — get token at vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=

# Public app URL — used for custom domain routing
NEXT_PUBLIC_APP_URL=http://localhost:3000
